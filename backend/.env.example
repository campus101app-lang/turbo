## Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dayfi?schema=public"

## App
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"

## Auth
JWT_SECRET="replace-with-strong-random-secret"
JWT_EXPIRES_IN="7d"

## Wallet / Encryption
WALLET_ENCRYPTION_KEY="replace-with-64-char-hex"
CVV_SALT="replace-with-random-salt"

## Stellar / Horizon
STELLAR_NETWORK="testnet"
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"
USDC_ISSUER="replace-with-usdc-issuer"
NGNT_ISSUER="replace-with-ngnt-issuer"
GOLD_ISSUER="replace-with-gold-issuer"
BTC_ISSUER="replace-with-btc-issuer"
MASTER_WALLET_PUBLIC_KEY="replace-with-master-public-key"
MASTER_WALLET_SECRET_KEY="replace-with-master-secret-key"
FUNDING_AMOUNT="1.5"

## Email (Resend)
RESEND_API_KEY="replace-with-resend-api-key"
FROM_EMAIL="noreply@example.com"
FROM_NAME="DayFi"

## Payments (Flutterwave)
FLUTTERWAVE_SECRET_KEY="replace-with-flutterwave-secret-key"
FLUTTERWAVE_WEBHOOK_HASH="replace-with-flutterwave-webhook-hash"
AUTO_SETTLE_NGNT_TOPUPS="true"

## Push Notifications (Firebase Admin)
FIREBASE_PROJECT_ID="replace-with-firebase-project-id"
FIREBASE_PRIVATE_KEY="replace-with-firebase-private-key"
FIREBASE_CLIENT_EMAIL="replace-with-firebase-client-email"

## SEP / Anchor domains
HOME_DOMAIN="example.com"
API_DOMAIN="api.example.com"
WEB_AUTH_DOMAIN="api.example.com"
ANCHOR_SECRET_KEY="replace-with-anchor-secret"

## Admin and operations
ADMIN_EMAILS="owner@example.com,admin@example.com"

## Swap provider keys (optional but recommended)
ZERO_X_API_KEY=""
CHANGELLY_API_KEY=""
CHANGELLY_SECRET_KEY=""

## EVM / Solana (optional for multi-chain features)
ALCHEMY_API_KEY=""
ETH_RPC_URL="https://cloudflare-eth.com"
ARB_RPC_URL="https://arb1.arbitrum.io/rpc"
POLY_RPC_URL="https://polygon-rpc.com"
AVAX_RPC_URL="https://api.avax.network/ext/bc/C/rpc"
USDC_ETH_ADDRESS=""
USDC_ARB_ADDRESS=""
USDC_POLY_ADDRESS=""
USDC_AVAX_ADDRESS=""
XAUT_ETH_ADDRESS=""
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
HELIUS_API_KEY=""
SOLANA_USDC_MINT=""
