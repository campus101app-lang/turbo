{
  "name": "dayfi-backend",
  "version": "1.0.0",
  "description": "DayFi Backend - Stellar USDC wallet with @dayfi.me usernames",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "prestart": "npx prisma migrate deploy",
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:critical": "vitest run tests/critical-path",
    "test:security": "vitest run tests/security",
    "test:integration": "vitest run tests/integration",
    "test:performance": "vitest run tests/performance",
    "test:e2e": "vitest run tests/e2e",
    "test:all": "npm run test:critical && npm run test:security && npm run test:integration && npm run test:performance",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "kill-port": "lsof -ti:3001 | xargs kill -9 || true"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^12.0.0",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "ecpair": "^3.0.1",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^6.16.0",
    "express": "^4.22.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.3.2",
    "firebase-admin": "^13.8.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "resend": "^3.2.0",
    "stellar-hd-wallet": "^1.0.2",
    "stellar-sdk": "^13.3.0",
    "tiny-secp256k1": "^2.2.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0",
    "supertest": "^7.1.1",
    "vitest": "^2.1.5",
    "@vitest/coverage-v8": "^2.1.5",
    "@vitest/ui": "^2.1.5"
  }
}
