// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  username    String? @unique
  isVerified  Boolean @default(false)

  // OTP
  otpCode     String?
  otpExpiry   DateTime?
  otpAttempts Int     @default(0)

  // Stellar wallet
  stellarPublicKey  String? @unique
  stellarSecretKey  String?
  encryptedMnemonic String?
  xlmReserved       Float   @default(0)  // Reserved XLM (locked by master wallet)

  // Security & backup
  faceIdEnabled Boolean @default(false)
  isBackedUp    Boolean @default(false)

  // ── Business profile ───────────────────────────────────
  fullName          String?
  businessName      String?
  businessCategory  String?
  businessEmail     String?

  // ── Virtual account (Flutterwave) ──────────────────────
  virtualAccountNumber String?
  virtualAccountBank   String?
  virtualAccountName   String?

  // ── Merchant / inventory ────────────────────────────────
  isMerchant        Boolean @default(false)
  inventory         InventoryItem[]

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  transactions        Transaction[]
  deviceTokens        DeviceToken[]
  invoices            Invoice[]
  expenseSubmissions  Expense[]          @relation("SubmittedBy")
  expenseApprovals    Expense[]          @relation("ApprovedBy")
  flutterwavePayments FlutterwavePayment[]
  cards               Card[]
  workflows           Workflow[]
  paymentRequests     PaymentRequest[]

  @@index([email])
  @@index([username])
  @@index([stellarPublicKey])
}

model Transaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   TransactionType
  status TransactionStatus @default(pending)

  amount Float
  asset  String             // USDC | NGNT | XLM

  network String @default("stellar")  // stellar | flutterwave

  fromAddress String?
  toAddress   String?
  toUsername  String?

  stellarTxHash String? @unique

  memo String?
  fee  Float?

  // Swap-specific
  isSwap        Boolean @default(false)
  swapId        String?
  swapFromAsset String?
  swapToAsset   String?
  receivedAmount Float?

  // Fiat-specific (Flutterwave)
  flutterwaveRef    String?
  fiatAmount        Float?
  fiatCurrency      String?
  flutterwaveStatus String?

  // Linkages
  invoiceId       String?
  invoice         Invoice?        @relation(fields: [invoiceId], references: [id])
  expenseId       String?
  expense         Expense?        @relation(fields: [expenseId], references: [id])
  paymentRequestId String?
  paymentRequest  PaymentRequest? @relation(fields: [paymentRequestId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([asset])
  @@index([flutterwaveRef])
}

// ── Invoice ───────────────────────────────────────────────────────────────────

model Invoice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  invoiceNumber String   @unique
  title         String
  description   String?

  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientAddress String?

  lineItems     Json

  subtotal      Float
  vatAmount     Float   @default(0)
  totalAmount   Float
  currency      String  @default("NGNT")  // NGNT | USDC

  paymentType        InvoicePaymentType @default(crypto)
  bankAccountDetails Json?
  paymentLink        String?

  status        InvoiceStatus @default(draft)
  dueDate       DateTime?
  sentAt        DateTime?
  viewedAt      DateTime?
  paidAt        DateTime?

  isRecurring        Boolean @default(false)
  recurringInterval  RecurringInterval?
  nextDueDate        DateTime?

  vatEnabled    Boolean @default(false)
  vatRate       Float   @default(7.5)

  transactions  Transaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([invoiceNumber])
}

// ── Expense ───────────────────────────────────────────────────────────────────

model Expense {
  id           String @id @default(cuid())

  submittedById String
  submittedBy   User  @relation("SubmittedBy", fields: [submittedById], references: [id])

  approvedById  String?
  approvedBy    User?  @relation("ApprovedBy", fields: [approvedById], references: [id])

  title         String
  description   String?
  amount        Float
  currency      String  @default("NGN")
  onChainAsset  String? @default("NGNT")

  category      ExpenseCategory
  receiptUrl    String?

  status        ExpenseStatus @default(pending)
  rejectionNote String?

  reimbursedAt  DateTime?
  transactions  Transaction[]

  notes         String?
  approvedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([submittedById])
  @@index([status])
}

// ── Card ──────────────────────────────────────────────────────────────────────
// Virtual (and future physical) debit cards linked to user balances.

model Card {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Card identity
  cardNumber     String  @unique           // masked: last 4 digits stored, full number never stored
  last4          String                    // e.g. "4242"
  cardholderName String
  expiryMonth    Int                       // 1–12
  expiryYear     Int                       // e.g. 2028
  cvvHash        String?                   // hashed CVV, never plain text

  // Card type & currency
  type           CardType  @default(virtual)
  currency       CardCurrency @default(USDC) // USDC | NGN

  // Status
  status         CardStatus @default(active)
  frozenAt       DateTime?
  cancelledAt    DateTime?

  // Limits
  spendingLimit       Float?               // daily spend limit (optional)
  spendingLimitPeriod String? @default("daily") // daily | monthly

  // Provider (for future integrations e.g. Stripe Issuing, Union54)
  provider       String? @default("internal")
  providerCardId String?                   // external card ID from provider

  // Metadata
  label          String?                   // user-defined nickname e.g. "Marketing Card"
  color          String? @default("#6C47FF") // hex color for card UI

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ── Workflow ──────────────────────────────────────────────────────────────────
// Automation rules: trigger → action.

model Workflow {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Trigger: what event starts this workflow
  triggerType  WorkflowTrigger
  triggerConfig Json            // e.g. { "day": 1, "month": "*" } for monthly payroll

  // Action: what happens when triggered
  actionType   WorkflowAction
  actionConfig Json            // e.g. { "to": "user@dayfi.me", "amount": 500, "asset": "USDC" }

  // Status
  status       WorkflowStatus @default(active)
  pausedAt     DateTime?

  // Execution tracking
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  runCount     Int @default(0)
  failCount    Int @default(0)
  lastError    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nextRunAt])
}

// ── PaymentRequest ────────────────────────────────────────────────────────────
// Lightweight "pay me" requests — simpler than invoices.

model PaymentRequest {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Request details
  requestNumber String  @unique            // e.g. REQ-2025-0001
  amount        Float
  asset         String  @default("USDC")  // USDC | NGNT | XLM

  note          String?                   // optional message to payer
  payerName     String?                   // who you're requesting from
  payerEmail    String?

  // Payment link
  paymentLink   String?

  // Status
  status        RequestStatus @default(pending)
  paidAt        DateTime?
  expiresAt     DateTime?                 // optional expiry

  // Paid transaction linkage
  transactions  Transaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([requestNumber])
}

// ── FlutterwavePayment ────────────────────────────────────────────────────────

model FlutterwavePayment {
  id            String @id @default(cuid())
  userId        String
  user          User   @relation(fields: [userId], references: [id])

  txRef         String @unique
  flwRef        String?

  type          FwPaymentType
  fiatAmount    Float
  onChainAmount Float?
  currency      String @default("NGN")

  status        FwPaymentStatus @default(initiated)
  providerStatus String?
  providerMessage String?
  retryCount    Int    @default(0)
  lastRetriedAt DateTime?
  idempotencyKey String?

  bankCode      String?
  accountNumber String?
  accountName   String?

  customerEmail String?
  customerName  String?
  redirectUrl   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([txRef])
  @@index([flwRef])
  @@index([idempotencyKey])
}

// ── DeviceToken ───────────────────────────────────────────────────────────────

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── InventoryItem ─────────────────────────────────────────────────────────────

model InventoryItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  sku       String?
  priceUsdc Float
  stock     Int      @default(0)
  threshold Int      @default(5)
  barcode   String?
  imageUrl  String?
  category  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sku])
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum TransactionType {
  send
  receive
  swap
  fiatDeposit
  fiatWithdrawal
  invoicePayment
  expenseReimbursement
  requestPayment
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

enum InvoiceStatus {
  draft
  sent
  viewed
  paid
  overdue
  cancelled
}

enum InvoicePaymentType {
  crypto
  bankTransfer
  both
}

enum RecurringInterval {
  weekly
  monthly
  quarterly
  annually
}

enum ExpenseCategory {
  travel
  meals
  accommodation
  equipment
  software
  marketing
  utilities
  salary
  other
}

enum ExpenseStatus {
  pending
  approved
  rejected
  reimbursed
}

enum FwPaymentType {
  deposit
  withdrawal
}

enum FwPaymentStatus {
  initiated
  pending
  successful
  failed
}

enum CardType {
  virtual
  physical
}

enum CardCurrency {
  USDC
  NGN
}

enum CardStatus {
  active
  frozen
  cancelled
}

enum WorkflowTrigger {
  scheduled          // runs on a cron-like schedule
  balanceThreshold   // triggers when balance drops below X
  invoicePaid        // triggers when an invoice is marked paid
  expenseApproved    // triggers when an expense is approved
  manualRun          // user triggers it manually
}

enum WorkflowAction {
  sendPayment        // auto-send funds to a recipient
  createInvoice      // auto-generate a recurring invoice
  sendReminder       // send payment reminder notification
  notifyUser         // push notification to user
  flagExpense        // flag expense for review
}

enum WorkflowStatus {
  active
  paused
  archived
}

enum RequestStatus {
  pending
  paid
  expired
  cancelled
}
