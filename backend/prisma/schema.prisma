// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  INDIVIDUAL
  REGISTERED_BUSINESS
  OTHER_ENTITY
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  LIMITED_LIABILITY
  PUBLIC_LIMITED
  PARTNERSHIP
  NGO
  RELIGIOUS_ORG
  TRUST
  OTHER
}

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  username    String? @unique
  isVerified  Boolean @default(false)
  
  // Account Type for Nigerian Businesses
  accountType AccountType @default(INDIVIDUAL)

  // OTP
  otpCode     String?
  otpExpiry   DateTime?
  otpAttempts Int     @default(0)

  // Stellar wallet
  stellarPublicKey  String? @unique
  stellarSecretKey  String?
  encryptedMnemonic String?
  xlmReserved       Float   @default(0)  // Reserved XLM (locked by master wallet)

  // Security & backup
  faceIdEnabled Boolean @default(false)
  isBackedUp    Boolean @default(false)

  // ── Nigeria Business Profile ───────────────────────────
  fullName          String?
  phone             String?
  homeAddress       String?
  
  // Business Information
  businessName      String?
  businessAddress   String?
  businessType      BusinessType?
  cacRegistrationNumber String?
  taxIdentificationNumber String?
  
  // KYC Documents
  bvn               String?
  nin               String?
  idType            String? // NIN, DRIVERS_LICENSE, VOTER_CARD
  idNumber          String?

  orders Order[]
  
  // Legacy fields (for compatibility)
  businessCategory  String?
  businessEmail     String?

  // ── Virtual account (Flutterwave) ──────────────────────
  virtualAccountNumber String?
  virtualAccountBank   String?
  virtualAccountName   String?

  // ── Merchant / inventory ────────────────────────────────
  isMerchant        Boolean @default(false)
  inventory         InventoryItem[]

  // ── Organization relationships ─────────────────────────────
  ownedOrganizations Organization[] @relation("OrganizationOwner")
  organizationMemberships OrganizationMember[]

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  transactions        Transaction[]
  deviceTokens        DeviceToken[]
  invoices            Invoice[]
  invoiceApprovals    Invoice[]           @relation("InvoiceApprovedBy")
  expenseSubmissions  Expense[]          @relation("SubmittedBy")
  expenseApprovals    Expense[]          @relation("ApprovedBy")
  flutterwavePayments FlutterwavePayment[]
  cards               Card[]
  workflows           Workflow[]
  paymentRequests     PaymentRequest[]
  auditLogs           AuditLog[]

  @@index([email])
  @@index([username])
  @@index([stellarPublicKey])
}

model Transaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   TransactionType
  status TransactionStatus @default(pending)

  amount Float
  asset  String             // USDC | NGNT | XLM

  network String @default("stellar")  // stellar | flutterwave

  fromAddress String?
  toAddress   String?
  toUsername  String?

  stellarTxHash String? @unique

  memo String?
  fee  Float?

  // Swap-specific
  isSwap        Boolean @default(false)
  swapId        String?
  swapFromAsset String?
  swapToAsset   String?
  receivedAmount Float?

  // Fiat-specific (Flutterwave)
  flutterwaveRef    String?
  fiatAmount        Float?
  fiatCurrency      String?
  flutterwaveStatus String?

  // Linkages
  invoiceId       String?
  invoice         Invoice?        @relation(fields: [invoiceId], references: [id])
  expenseId       String?
  expense         Expense?        @relation(fields: [expenseId], references: [id])
  paymentRequestId String?
  paymentRequest  PaymentRequest? @relation(fields: [paymentRequestId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([asset])
  @@index([flutterwaveRef])
}

// ── Invoice ───────────────────────────────────────────────────────────────────

model Invoice {
  id             String @id @default(cuid())
  userId         String
  user           User   @relation(fields: [userId], references: [id])
  
  // Organization support
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  // Approval workflow
  approvedById   String?
  approvedBy     User?  @relation("InvoiceApprovedBy", fields: [approvedById], references: [id])
  approvalLevel  Int?   // Current approval level (1, 2, 3...)
  requiredApprovals Int @default(1) // Number of approvals needed

  invoiceNumber String   @unique
  title         String
  description   String?

  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientAddress String?

  lineItems     Json

  subtotal      Float
  vatAmount     Float   @default(0)
  totalAmount   Float
  currency      String  @default("NGNT")  // NGNT | USDC

  paymentType        InvoicePaymentType @default(crypto)
  bankAccountDetails Json?
  paymentLink        String?

  status        InvoiceStatus @default(draft)
  dueDate       DateTime?
  sentAt        DateTime?
  viewedAt      DateTime?
  paidAt        DateTime?

  isRecurring        Boolean @default(false)
  recurringInterval  RecurringInterval?
  nextDueDate        DateTime?

  vatEnabled    Boolean @default(false)
  vatRate       Float   @default(7.5)

  transactions  Transaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([invoiceNumber])
}

// ── Expense ───────────────────────────────────────────────────────────────────

model Expense {
  id           String @id @default(cuid())

  submittedById String
  submittedBy   User  @relation("SubmittedBy", fields: [submittedById], references: [id])

  approvedById  String?
  approvedBy    User?  @relation("ApprovedBy", fields: [approvedById], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  title         String
  description   String?
  amount        Float
  currency      String  @default("NGN")
  onChainAsset  String? @default("NGNT")

  category      ExpenseCategory
  receiptUrl    String?

  status        ExpenseStatus @default(pending)
  rejectionNote String?

  reimbursedAt  DateTime?
  transactions  Transaction[]

  notes         String?
  approvedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([submittedById])
  @@index([status])
  @@index([organizationId])
}

// ── Card ──────────────────────────────────────────────────────────────────────
// Virtual (and future physical) debit cards linked to user balances.

model Card {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Card identity
  cardNumber     String  @unique           // masked: last 4 digits stored, full number never stored
  last4          String                    // e.g. "4242"
  cardholderName String
  expiryMonth    Int                       // 1–12
  expiryYear     Int                       // e.g. 2028
  cvvHash        String?                   // hashed CVV, never plain text

  // Card type & currency
  type           CardType  @default(virtual)
  currency       CardCurrency @default(USDC) // USDC | NGN

  // Status
  status         CardStatus @default(active)
  frozenAt       DateTime?
  cancelledAt    DateTime?

  // Limits
  spendingLimit       Float?               // daily spend limit (optional)
  spendingLimitPeriod String? @default("daily") // daily | monthly

  // Provider (for future integrations e.g. Stripe Issuing, Union54)
  provider       String? @default("internal")
  providerCardId String?                   // external card ID from provider

  // Metadata
  label          String?                   // user-defined nickname e.g. "Marketing Card"
  color          String? @default("#6C47FF") // hex color for card UI

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ── Workflow ──────────────────────────────────────────────────────────────────
// Automation rules: trigger → action.

model Workflow {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name        String
  description String?

  // Trigger: what event starts this workflow
  triggerType  WorkflowTrigger
  triggerConfig Json            // e.g. { "day": 1, "month": "*" } for monthly payroll

  // Action: what happens when triggered
  actionType   WorkflowAction
  actionConfig Json            // e.g. { "to": "user@dayfi.me", "amount": 500, "asset": "USDC" }

  // Status
  status       WorkflowStatus @default(active)
  pausedAt     DateTime?

  // Execution tracking
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  runCount     Int @default(0)
  failCount    Int @default(0)
  lastError    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nextRunAt])
}

// ── PaymentRequest ────────────────────────────────────────────────────────────
// Lightweight "pay me" requests — simpler than invoices.

model PaymentRequest {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Request details
  requestNumber String  @unique            // e.g. REQ-2025-0001
  amount        Float
  asset         String  @default("USDC")  // USDC | NGNT | XLM

  note          String?                   // optional message to payer
  payerName     String?                   // who you're requesting from
  payerEmail    String?

  // Payment link
  paymentLink   String?

  // Status
  status        RequestStatus @default(pending)
  paidAt        DateTime?
  expiresAt     DateTime?                 // optional expiry

  // Paid transaction linkage
  transactions  Transaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([requestNumber])
}

// ── FlutterwavePayment ────────────────────────────────────────────────────────

model FlutterwavePayment {
  id            String @id @default(cuid())
  userId        String
  user          User   @relation(fields: [userId], references: [id])

  txRef         String @unique
  flwRef        String?

  type          FwPaymentType
  fiatAmount    Float
  onChainAmount Float?
  currency      String @default("NGN")

  status        FwPaymentStatus @default(initiated)
  providerStatus String?
  providerMessage String?
  retryCount    Int    @default(0)
  lastRetriedAt DateTime?
  idempotencyKey String?

  bankCode      String?
  accountNumber String?
  accountName   String?

  customerEmail String?
  customerName  String?
  redirectUrl   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([txRef])
  @@index([flwRef])
  @@index([idempotencyKey])
}

// ── DeviceToken ───────────────────────────────────────────────────────────────

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── InventoryItem ─────────────────────────────────────────────────────────────

model InventoryItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String?
  name      String
  sku       String?
  priceUsdc Float
  stock     Int      @default(0)
  threshold Int      @default(5)
  barcode   String?
  imageUrl  String?
  category  String?
  isActive    Boolean   @default(true)
  orders      OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sku])
}

// ─── Organization ──────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  domain      String?  @unique
  plan        OrganizationPlan @default(free)
  maxMembers  Int      @default(5)
  
  ownerUserId String
  owner       User     @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  members     OrganizationMember[]
  invoices    Invoice[]
  expenses    Expense[]
  workflows   Workflow[]
  auditLogs   AuditLog[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

// ── OrganizationMember ────────────────────────────────────────────────────────

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role           OrganizationRole @default(staff)
  permissions    Json?    // Custom permissions per role
  invitedBy      String?
  joinedAt       DateTime @default(now())
  
  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}
enum TransactionType {
  send
  receive
  swap
  fiatDeposit
  fiatWithdrawal
  invoicePayment
  expenseReimbursement
  requestPayment
}

enum InvoiceStatus {
  draft
  sent
  viewed
  paid
  overdue
  cancelled
}

enum ExpenseStatus {
  pending
  submitted
  approved
  rejected
  reimbursed
}

enum ExpenseCategory {
  software
  hardware
  marketing
  travel
  office
  utilities
  other
  meals
  accommodation
  equipment
  salary
}

enum CardType {
  virtual
  physical
}

enum CardCurrency {
  USDC
  NGN
}

enum CardStatus {
  active
  frozen
  cancelled
  expired
}

enum InvoicePaymentType {
  crypto
  bank
  bankTransfer
  both
}

enum WorkflowStatus {
  active
  paused
  disabled
  archived
}

enum WorkflowTriggerType {
  scheduled
  balanceThreshold
  invoicePaid
  expenseApproved
  manualRun
}

enum WorkflowActionType {
  sendPayment
  createInvoice
  sendReminder
  notifyUser
  flagExpense
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

// ── Audit Log ────────────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  action        String   // e.g., "transaction_send", "invoice_created", "permission_role_changed"
  resourceType  String   // e.g., "transaction", "invoice", "organization_member"
  resourceId    String?  // ID of the affected resource
  details       Json?    // Additional context data
  
  ipAddress     String?
  userAgent     String?
  timestamp     DateTime @default(now())
  
  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([resourceType])
  @@index([timestamp])
  @@index([organizationId, timestamp])
}


enum RecurringInterval {
  weekly
  monthly
  quarterly
  annually
}

enum FwPaymentType {
  deposit
  withdrawal
}

enum FwPaymentStatus {
  initiated
  pending
  successful
  failed
}

enum RequestStatus {
  pending
  paid
  expired
  cancelled
}

enum OrganizationPlan {
  free
  starter
  pro
  enterprise
}

enum OrganizationRole {
  owner
  admin
  manager
  staff
}

enum WorkflowTrigger {
  scheduled
  balanceThreshold
  invoicePaid
  expenseApproved
  manualRun
}

enum WorkflowAction {
  sendPayment
  createInvoice
  sendReminder
  notifyUser
  flagExpense
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])

  orderNumber String     @unique
  status      OrderStatus @default(pending)

  customerName  String?
  customerEmail String?
  customerPhone String?

  items         OrderItem[]
  totalUsdc     Float
  notes         String?

  stellarTxHash String?
  paidAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  name      String
  priceUsdc Float
  quantity  Int

  @@index([orderId])
}

enum OrderStatus {
  pending
  confirmed
  fulfilled
  cancelled
  refunded
}