// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  username    String? @unique          // now optional — legacy users keep theirs
  isVerified  Boolean @default(false)

  // OTP
  otpCode     String?
  otpExpiry   DateTime?
  otpAttempts Int     @default(0)

  // Stellar wallet
  stellarPublicKey  String? @unique
  stellarSecretKey  String?           // AES-256-GCM encrypted
  encryptedMnemonic String?           // BIP-39 mnemonic, AES-256-GCM encrypted

  // Security & backup
  faceIdEnabled Boolean @default(false)
  isBackedUp    Boolean @default(false)

  // ── Business profile (new) ─────────────────────────────
  fullName          String?
  businessName      String?
  businessCategory  String?
  businessEmail     String?           // separate from login email, optional

  // ── Merchant / inventory (existing) ────────────────────
  isMerchant        Boolean @default(false)
  inventory         InventoryItem[]

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  transactions        Transaction[]
  deviceTokens        DeviceToken[]
  invoices            Invoice[]
  expenseSubmissions  Expense[]         @relation("SubmittedBy")
  expenseApprovals    Expense[]         @relation("ApprovedBy")
  flutterwavePayments FlutterwavePayment[]

  @@index([email])
  @@index([username])
  @@index([stellarPublicKey])
}

model Transaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   TransactionType
  status TransactionStatus @default(pending)

  amount Float
  // USDC | NGNT | XLM
  asset  String

  // stellar | flutterwave
  network String @default("stellar")

  fromAddress String?
  toAddress   String?
  toUsername  String?

  stellarTxHash String? @unique

  memo String?
  fee  Float?

  // Swap-specific fields
  isSwap        Boolean @default(false)
  swapId        String?
  swapFromAsset String?
  swapToAsset   String?
  receivedAmount Float?

  // Fiat-specific (Flutterwave)
  flutterwaveRef    String?           // Flutterwave transaction reference
  fiatAmount        Float?            // NGN amount paid by user
  fiatCurrency      String?           // "NGN"
  flutterwaveStatus String?           // "successful" | "failed" | "pending"

  // Invoice linkage
  invoiceId     String?
  invoice       Invoice? @relation(fields: [invoiceId], references: [id])

  // Expense linkage
  expenseId     String?
  expense       Expense? @relation(fields: [expenseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([asset])
  @@index([flutterwaveRef])
}

// ── Invoice ───────────────────────────────────────────────────────────────────

model Invoice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  invoiceNumber String   @unique         // e.g. INV-2024-0001
  title         String
  description   String?

  // Client details
  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientAddress String?

  // Line items stored as JSON: [{ description, quantity, unitPrice, vatRate }]
  lineItems     Json

  // Totals
  subtotal      Float
  vatAmount     Float   @default(0)
  totalAmount   Float
  currency      String  @default("NGNT")  // NGNT | USDC

  // Payment settings
  paymentType   InvoicePaymentType @default(crypto)
  bankAccountDetails Json?           // for NGN bank-transfer invoices
  paymentLink   String?              // generated shareable link

  // Status & dates
  status        InvoiceStatus @default(draft)
  dueDate       DateTime?
  sentAt        DateTime?
  viewedAt      DateTime?
  paidAt        DateTime?

  // Recurring
  isRecurring   Boolean @default(false)
  recurringInterval RecurringInterval?
  nextDueDate   DateTime?

  // VAT
  vatEnabled    Boolean @default(false)
  vatRate       Float   @default(7.5)    // Nigeria standard VAT 7.5%

  transactions  Transaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([invoiceNumber])
}

// ── Expense ───────────────────────────────────────────────────────────────────

model Expense {
  id           String @id @default(cuid())

  // Submitted by employee
  submittedById String
  submittedBy   User  @relation("SubmittedBy", fields: [submittedById], references: [id])

  // Approved/rejected by manager
  approvedById  String?
  approvedBy    User?  @relation("ApprovedBy", fields: [approvedById], references: [id])

  title         String
  description   String?
  amount        Float
  currency      String  @default("NGN")   // NGN | USDC
  onChainAsset  String? @default("NGNT")  // the Stellar asset used for reimbursement

  category      ExpenseCategory
  receiptUrl    String?                   // uploaded receipt image URL

  status        ExpenseStatus @default(pending)
  rejectionNote String?

  // Reimbursement
  reimbursedAt  DateTime?
  transactions  Transaction[]

  // Notes / audit
  notes         String?
  approvedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([submittedById])
  @@index([status])
}

// ── FlutterwavePayment ────────────────────────────────────────────────────────
// Tracks each Flutterwave payment session (both deposits and withdrawals)

model FlutterwavePayment {
  id            String @id @default(cuid())
  userId        String
  user          User   @relation(fields: [userId], references: [id])

  txRef         String @unique             // our generated reference
  flwRef        String?                    // Flutterwave's reference (set after payment)

  type          FwPaymentType             // deposit | withdrawal
  fiatAmount    Float                     // NGN amount
  onChainAmount Float?                    // NGNT credited/debited on Stellar
  currency      String @default("NGN")

  status        FwPaymentStatus @default(initiated)

  // For withdrawals
  bankCode      String?
  accountNumber String?
  accountName   String?

  // Metadata
  customerEmail String?
  customerName  String?
  redirectUrl   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([txRef])
  @@index([flwRef])
}

// ── DeviceToken ───────────────────────────────────────────────────────────────

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String                       // ios | android
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── InventoryItem ─────────────────────────────────────────────────────────────

model InventoryItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  sku       String?
  priceUsdc Float
  stock     Int      @default(0)
  threshold Int      @default(5)
  barcode   String?
  imageUrl  String?
  category  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sku])
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum TransactionType {
  send
  receive
  swap
  fiatDeposit    // Flutterwave NGN → NGNT credit
  fiatWithdrawal // NGNT burn → Flutterwave NGN payout
  invoicePayment
  expenseReimbursement
}

enum TransactionStatus {
  pending
  confirmed
  failed
}

enum InvoiceStatus {
  draft
  sent
  viewed
  paid
  overdue
  cancelled
}

enum InvoicePaymentType {
  crypto      // NGNT or USDC on-chain
  bankTransfer // NGN via Flutterwave payment link
  both        // user can choose at payment time
}

enum RecurringInterval {
  weekly
  monthly
  quarterly
  annually
}

enum ExpenseCategory {
  travel
  meals
  accommodation
  equipment
  software
  marketing
  utilities
  salary
  other
}

enum ExpenseStatus {
  pending
  approved
  rejected
  reimbursed
}

enum FwPaymentType {
  deposit
  withdrawal
}

enum FwPaymentStatus {
  initiated
  pending
  successful
  failed
}
