# ─── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────
# PostgreSQL connection string
# Local:   postgresql://postgres:password@localhost:5432/dayfi
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/dayfi"

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="30d"

# ─── Wallet Encryption ────────────────────────────────────
# Must be 64 hex characters (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY="a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2"

# ─── Master Wallet (Stellar) ──────────────────────────────
MASTER_WALLET_PUBLIC_KEY="your-master-wallet-public-key"
MASTER_WALLET_SECRET_KEY="your-encrypted-master-wallet-secret"
FUNDING_AMOUNT="3.0"

# ─── Admin Access (Comma-separated emails) ────────────────
# Users with these emails can call /api/wallet/admin/send
ADMIN_EMAILS="admin@example.com,dev@example.com"

# ─── Stellar ──────────────────────────────────────────────
# testnet | mainnet
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Mainnet USDC issuer (Circle)
USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# Testnet USDC issuer
# USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ─── Master Wallet for Auto-Funding ──────────────────────
# Public key of master wallet (used to fund new user wallets)
MASTER_WALLET_PUBLIC_KEY=your_master_public_key
# Encrypted secret key (use walletService.js encrypt() to generate)
# IMPORTANT: Keep this secure! Store in secret management system in production
MASTER_WALLET_SECRET_KEY=your_encrypted_secret_key
# Amount of XLM to fund each new user (minimum 2 for reserve + trustline)
FUNDING_AMOUNT=5

# ─── Email ────────────────────────────────────────────────
# Option 1: Resend (recommended — https://resend.com)
RESEND_API_KEY=re_your_resend_api_key

# Option 2: Gmail SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Sender identity
FROM_EMAIL=noreply@dayfi.me
FROM_NAME=DayFi

# ─── Firebase (Push Notifications) ───────────────────────
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
