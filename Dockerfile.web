# Dockerfile for DayFi Flutter Web App
# Optimized for Railway deployment

FROM python:3.11-slim as web-server

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy Flutter web build
COPY build/web/ ./web/

# Create health check endpoint
RUN echo '<!DOCTYPE html><html><head><title>Health Check</title></head><body><h1>DayFi Web App - Healthy</h1></body></html>' > web/health.html

# Health check configuration
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/health.html || exit 1

# Expose port
EXPOSE 8080

# Start web server with proper headers
CMD ["python", "-m", "http.server", "8080", "--directory", "web"]
